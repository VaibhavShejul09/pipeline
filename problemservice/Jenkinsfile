pipeline {
    agent {
        docker {
            image 'shejulv088/maven-docker-agent:v1'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        DOCKERHUB_USER = "shejulv088"
        APP_NAME = "problemservice"
        IMAGE_REPO = "${DOCKERHUB_USER}/${APP_NAME}"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/VaibhavShejul09/pipeline.git'
            }
        }

         stage('Build & Test') {
            steps {
                dir('problemservice') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }


        stage('Prepare Image Tags') {
            steps {
                script {
                    def shortSha = sh(
                        script: "git rev-parse --short HEAD",
                        returnStdout: true
                    ).trim()

                    env.IMMUTABLE_TAG = shortSha
                    env.METADATA_TAG  = "build-${BUILD_NUMBER}-${shortSha}"

                    echo "Immutable Tag : ${IMMUTABLE_TAG}"
                    echo "Metadata Tag  : ${METADATA_TAG}"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('problemservice') {
                    sh """
                          docker build \
                              -t ${IMAGE_REPO}:${IMMUTABLE_TAG} \
                              -t ${IMAGE_REPO}:${METADATA_TAG} .
                       """
                }
                
            }
        }

        stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                    echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin
                    """
                }
            }
        }

        stage('Push Image to Docker Hub') {
            steps {
                script {
                   docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
                   sh "docker push ${IMAGE_REPO}:${IMMUTABLE_TAG}"
                   sh "docker push ${IMAGE_REPO}:${METADATA_TAG}"
               }
           }
       }
    }
    

    post {
        success {
            echo "Image pushed to Docker Hub successfully"
        }
    }
}

