pipeline {
  agent {
    docker {
      image 'docker.io/shejulv088/maven-docker-agent'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
    }
  }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo passed'
        //git branch: 'main', url: 'https://github.com/VaibhavShejul09/pipeline.git'
      }
    }
  }
    stage('Build and Test') {
      steps {
        sh 'ls -ltr'
        // build the project and create a JAR file
        
      }
    }
    
}
